{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler"
  },
  "include": ["src"],
  "exclude": [
    "src/components/DocumentUploader.tsx",
    "src/components/DocumentUploader.tsx.bak",
    "src/components/DocumentUploader.tsx.delete",
    "src/components/tmp-delete",
    "src/server-utils/convertPdfFirstPageToBase64.ts",
    "src/server-utils/convertPdfFirstPageToBase64.ts.bak",
    "src/server-utils/convertPdfFirstPageToBase64.ts.delete"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
